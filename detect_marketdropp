#RQ: To detect largest continuous market drop using an algorithm to see if it corresponds to spans of systemic risk?
#Hypothesis: There is a positive correlation between continuous market drop and spans of systemic risk.

#Method: Maximum array algorithm, Pearson correlation coefficient

#code
import numpy as np
def lowest_drop_subarray(returns):
    current_sum = returns[0]
    lowest_sum = returns[0]
    
    current_start = 0
    lowest_start = 0
    lowest_end = 0
    
    for i in range(1, len(returns)):
        if returns[i] < current_sum +returns[i]:
            current_sum = returns[i]
            current_start = i
        else:
            current_sum = current_sum + returns[i]
            
            if current_sum < lowest_sum:
                lowest_sum = current_sum
                lowest_start = current_start
                lowest_end = i
    return lowest_sum, lowest_start, lowest_end
    
def main():
    returns = [200, 300, -100, -50, 400, -400, -500, 100]
    lowest_sum, initial, end = lowest_drop_subarray(returns)
    variable = [abs(x) for x in returns]
    parameter = [0]*len(returns)
    for i in range(initial, end + 1):
        parameter[i] = 1
    correlation = np.corrcoef(parameter, variable)[0,1]

    
    print('Return on a given day:', returns)
    print('Lowest continuous market drop:', lowest_sum)
    print('End value:', end)
    print('Crash window:', returns[initial:end+1])
    print('varibale:', variable)
    print('Correlation between drop span and variables')
    print('Pearson correlation', correlation)
    
    if correlation < 0:
        print('Conclude: Continuos loss period was not positively correlated')
    elif correlation > 0:
        print('Conclude: Continuos loss period was positively correlated')
    else:
        print('Conclude: No association')
main()
